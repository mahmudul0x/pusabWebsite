# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave empty to use local SQLite (dev).
# For Postgres (Supabase/Neon/Render), set the full connection URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# CORS — your React frontend origins (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudinary (the React frontend uploads directly; backend only needs these
# if you later add signed uploads / deletion)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
